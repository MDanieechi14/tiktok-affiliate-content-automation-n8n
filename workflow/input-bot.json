{
  "name": "TikTok Content Input Bot",
  "nodes": [
    {
      "parameters": {
        "updates": ["message"]
      },
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.2,
      "position": [0, 0],
      "id": "telegram-trigger-id",
      "name": "Telegram Input Trigger",
      "webhookId": "YOUR_WEBHOOK_ID",
      "credentials": {
        "telegramApi": {
          "id": "YOUR_TELEGRAM_CREDENTIAL_ID",
          "name": "Telegram API"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{ \"model\": \"llama-3.3-70b-versatile\", \"messages\": [{ \"role\": \"user\", \"content\": \"Generate TikTok hooks, script, caption, and CTA based on product input.\" }] }"
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [208, 0],
      "id": "groq-request-id",
      "name": "Generate Content (Groq)",
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_GROQ_API_ID",
          "name": "Groq API"
        }
      }
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "value": "YOUR_GOOGLE_SHEET_ID"
        },
        "sheetName": {
          "value": "Sheet1"
        }
      },
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [416, 0],
      "id": "save-to-sheet-id",
      "name": "Save Content to Sheet",
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "YOUR_GOOGLE_CREDENTIAL_ID",
          "name": "Google Sheets Credential"
        }
      }
    }
  ],
  "connections": {
    "Telegram Input Trigger": {
      "main": [
        [
          { "node": "Generate Content (Groq)", "type": "main", "index": 0 }
        ]
      ]
    },
    "Generate Content (Groq)": {
      "main": [
        [
          { "node": "Save Content to Sheet", "type": "main", "index": 0 }
        ]
      ]
    }
  }
}
